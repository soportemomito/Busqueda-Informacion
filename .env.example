# Copiar a server/.env (no commitear secretos)
# PowerShell: Copy-Item .env.example server\.env

PORT=3001

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

CHATWOOT_BASE_URL=https://helpdesk.soymomo.io
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# Bsale
BSALE_ACCESS_TOKEN=
# URL: si termina en /v1 el servidor usa solo el host (rutas ya llevan /v1/...)
BSALE_API_URL=https://api.bsale.io/v1
# BSALE_API_BASE_URL=https://api.bsale.cl

# Shopify — mínimo: SHOPIFY_ACCESS_TOKEN. Sin URL ni tienda en .env se usa SoyMomo Chile + API 2024-10 (estable).
SHOPIFY_ACCESS_TOKEN=
# Opcional (override): URL completa Admin API
# SHOPIFY_API_URL=https://soymomo-chile.myshopify.com/admin/api/2024-10
# O tienda + versión:
# SHOPIFY_STORE_URL=soymomo-chile.myshopify.com
# SHOPIFY_API_VERSION=2024-10
# Otra tienda sin repetir URL:
# SHOPIFY_SHOP_HOST=otra-tienda.myshopify.com
# Webhooks (solo si implementas endpoint):
SHOPIFY_WEBHOOK_SECRET=

# Google Drive (opcional) — compartir carpeta con client_email del JSON
DRIVE_PARENT_FOLDER_ID=
DRIVE_SERVICE_ACCOUNT_KEY=
